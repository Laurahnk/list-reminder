## Cellule 14 — MIA (Membership Inference Attack)

```python
from sklearn.ensemble import RandomForestClassifier
from sklearn.model_selection import cross_val_predict

def mia_test(df_real, df_synth, label=""):
    num_r = df_real.select_dtypes(include=[np.number]).columns.tolist()
    num_s = df_synth.select_dtypes(include=[np.number]).columns.tolist()
    common = list(set(num_r) & set(num_s))

    n = min(len(df_real), len(df_synth), 5000)
    X_r = df_real[common].fillna(0).sample(n, random_state=42).values
    X_s = df_synth[common].fillna(0).sample(n, random_state=42).values

    X = np.vstack([X_r, X_s])
    y = np.array([1]*n + [0]*n)

    scaler = StandardScaler()
    X_scaled = scaler.fit_transform(X)

    clf = RandomForestClassifier(n_estimators=100, max_depth=6,
                                  random_state=42, n_jobs=-1)
    proba = cross_val_predict(clf, X_scaled, y, cv=5, method="predict_proba")[:, 1]
    auc = roc_auc_score(y, proba)
    flag = "⚠️  Distinguable" if auc > 0.6 else "✅ Indiscernable"
    print(f"  [{label}] MIA AUC = {auc:.4f}  {flag}")
    return auc

print("=== MEMBERSHIP INFERENCE ATTACK ===")
print("→ AUC proche de 0.5 = bonne confidentialité\n")
auc_mia_bn    = mia_test(df, df_bn,    label="BayesianNetwork")
auc_mia_ctgan = mia_test(df, df_ctgan, label="CTGAN")
auc_mia_tvae  = mia_test(df, df_tvae,  label="TVAE")

fig, ax = plt.subplots(figsize=(8, 4))
vals = [auc_mia_bn, auc_mia_ctgan, auc_mia_tvae]
