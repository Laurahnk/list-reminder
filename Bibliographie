```python
def preprocess(df, max_missing_rate=0.40, n_sample=30_000):
    df = df.copy()

    # Suppression identifiant
    if "SK_ID_CURR" in df.columns:
        df = df.drop(columns=["SK_ID_CURR"])

    # Suppression colonnes trop lacunaires
    miss_rate = df.isnull().mean()
    cols_to_keep = miss_rate[miss_rate <= max_missing_rate].index.tolist()
    df = df[cols_to_keep]
    print(f"Colonnes conservées : {len(cols_to_keep)}")

    num_cols = df.select_dtypes(include=[np.number]).columns.tolist()
    cat_cols = df.select_dtypes(include=["object"]).columns.tolist()

    # Imputation
    for c in num_cols:
        df[c] = df[c].fillna(df[c].median())
    for c in cat_cols:
        df[c] = df[c].fillna(df[c].mode()[0])

    # Conversion catégorielles en str pour SDV
    df[cat_cols] = df[cat_cols].astype(str)

    # Échantillonnage stratifié sur TARGET
    df = (df.groupby("TARGET", group_keys=False)
            .apply(lambda x: x.sample(min(len(x), n_sample // 2), random_state=42)))
    df = df.reset_index(drop=True)

    print(f"Shape final : {df.shape}")
    print(f"Taux de défaut : {df['TARGET'].mean():.3f}")
    return df, num_cols, cat_cols


df, num_cols, cat_cols = preprocess(df_raw, n_sample=30_000)
df.to_parquet("df_preprocessed.parquet", index=False)
print("✅ Base prétraitée sauvegardée")
