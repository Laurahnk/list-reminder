from sklearn.model_selection import train_test_split
from sklearn.metrics import roc_auc_score
from sklearn.preprocessing import LabelEncoder
from xgboost import XGBClassifier

def score_utility(df_train, df_test, label=""):
    target = "TARGET"
    cat_local = df_train.select_dtypes(include="object").columns.tolist()

    X_tr = df_train.drop(columns=[target]).copy()
    y_tr = df_train[target].astype(int)
    X_te = df_test.drop(columns=[target]).copy()
    y_te = df_test[target].astype(int)

    common = list(set(X_tr.columns) & set(X_te.columns))
    X_tr, X_te = X_tr[common], X_te[common]

    le = LabelEncoder()
    for c in cat_local:
        if c in X_tr.columns:
            X_tr[c] = le.fit_transform(X_tr[c].astype(str))
            X_te[c] = le.transform(X_te[c].astype(str).apply(
                lambda x: x if x in le.classes_ else le.classes_[0]))

    X_tr = X_tr.apply(pd.to_numeric, errors="coerce").fillna(0)
    X_te = X_te.apply(pd.to_numeric, errors="coerce").fillna(0)

    model = XGBClassifier(n_estimators=200, max_depth=5, learning_rate=0.05,
                          use_label_encoder=False, eval_metric="auc",
                          random_state=42, verbosity=0)
    model.fit(X_tr, y_tr)
    auc = roc_auc_score(y_te, model.predict_proba(X_te)[:, 1])
    gini = 2 * auc - 1
    print(f"  [{label}] AUC = {auc:.4f} | Gini = {gini:.4f}")
    return auc


