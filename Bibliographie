# On s’intéresse à quelques variables num + cat pour le test
columns_use = [
    col for col in df.columns
    if col in df.select_dtypes(include=[np.number]) or col in df.select_dtypes(include=["object"])
    if col not in ["TARGET"]  # TARGET est la vraie cible crédit, pas pour ce test
][:20]  # astuce pour garder seulement ~20 colonnes

real_sample = real_sample[columns_use + ["TARGET"]].reset_index(drop=True)
synth_sample = synth_sample[columns_use].reset_index(drop=True)

print("Colonnes pour détection adverse :")
print(f"  n = {len(columns_use)}")

# On encode rapidement et robustement
ct = ColumnTransformer([
    ("num", StandardScaler(), [col for col in columns_use if col in real_sample.select_dtypes(include=[np.number]).columns]),
    ("cat", OneHotEncoder(drop="first", handle_unknown="ignore"), [col for col in columns_use if col in real_sample.select_dtypes(include=["object"]).columns])
], remainder="drop")

real_scaled = ct.fit_transform(real_sample)
synth_scaled = ct.transform(synth_sample)

# Création du jeu de données mélangé
