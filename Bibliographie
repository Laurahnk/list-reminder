## Cellule 13 — DCR (Distance to Closest Record)

```python
from sklearn.preprocessing import StandardScaler
from sklearn.neighbors import NearestNeighbors

def dcr_score(df_real, df_synth, n_sample=3000):
    num_r = df_real.select_dtypes(include=[np.number]).columns.tolist()
    num_s = df_synth.select_dtypes(include=[np.number]).columns.tolist()
    common = list(set(num_r) & set(num_s))

    X_r = df_real[common].fillna(0).values
    X_s = df_synth[common].fillna(0).values

    idx_r = np.random.choice(len(X_r), min(n_sample, len(X_r)), replace=False)
    idx_s = np.random.choice(len(X_s), min(n_sample, len(X_s)), replace=False)
    X_r, X_s = X_r[idx_r], X_s[idx_s]

    scaler = StandardScaler()
    X_r = scaler.fit_transform(X_r)
    X_s = scaler.transform(X_s)

    nn = NearestNeighbors(n_neighbors=1, algorithm="ball_tree", n_jobs=-1)
    nn.fit(X_r)
    dists_sr, _ = nn.kneighbors(X_s)
    dists_rr, _ = nn.kneighbors(X_r)

    ratio = dists_sr.mean() / max(dists_rr.mean(), 1e-9)
    return {"mean_sr": dists_sr.mean(), "mean_rr": dists_rr.mean(),
            "ratio": ratio}, dists_sr.flatten(), dists_rr.flatten()

print("=== DCR — Distance to Closest Record ===")
for label, ds in [("BayesianNetwork", df_bn), ("CTGAN", df_ctgan), ("TVAE", df_tvae)]:
    res, dists_sr, dists_rr = dcr_score(df, ds)
    print(f"\n  [{label}]")
    print(f"   DCR synth→réel : {res['mean_sr']:.4f}")
    print(f"   DCR réel→réel  : {res['mean_rr']:.4f}")
    print(f"   Ratio (> 1 = bon) : {res['ratio']:.3f}")

# Visualisation
fig, axes = plt.subplots(1, 3, figsize=(18, 5))
for ax, color, (label, ds) in zip(axes,
        ["darkorange", "tomato", "seagreen"],
        [("BayesianNetwork", df_bn), ("CTGAN", df_ctgan), ("TVAE", df_tvae)]):
    res, dists_sr, dists_rr = dcr_score(df, ds)
    ax.hist(dists_rr, bins=50, alpha=0.6, density=True,
            color="steelblue", label="Réel→Réel")
    ax.hist(dists_sr, bins=50, alpha=0.6, density=True,
            color=color, label="Synth→Réel")
    ax.set_title(f"{label}\nRatio = {res['ratio']:.3f}")
    ax.legend(fontsize=8)

plt.suptitle("DCR — Risque de réidentification", fontsize=13)
plt.tight_layout()
plt.savefig("dcr_comparison.png", dpi=120)
plt.show()
