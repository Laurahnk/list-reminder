def compute_l_diversity(df_, qi, sensitive_attr="TARGET"):
    return (df_.groupby(qi)[sensitive_attr]
              .nunique()
              .reset_index()
              .rename(columns={sensitive_attr: "l_diversity"}))

def enforce_l_diversity(df_, qi, sensitive_attr="TARGET", l=2):
    div = compute_l_diversity(df_, qi, sensitive_attr)
    valid = div[div["l_diversity"] >= l]
    df_l = df_.merge(valid[qi], on=qi, how="inner")
    print(f"  ℓ={l} → {len(df_l)} lignes conservées ({len(df_l)/len(df_)*100:.1f}%)")
    return df_l

