               color=["darkorange", "tomato", "seagreen"])
ax.axvline(0.5, color="red",    linestyle="--", linewidth=2, label="Parfaite conf. (0.5)")
ax.axvline(0.6, color="orange", linestyle=":",  linewidth=2, label="Seuil risque (0.6)")
for bar, val in zip(bars, vals):
    ax.text(val + 0.005, bar.get_y() + bar.get_height()/2,
            f"{val:.4f}", va="center", fontsize=10)
ax.set_xlabel("AUC (MIA)")
ax.set_title("Membership Inference Attack — Confidentialité")
ax.legend()
plt.tight_layout()
plt.savefig("mia_comparison.png", dpi=120)
plt.show()
