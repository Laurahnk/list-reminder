sensitive_col = 'TARGET' # La cible ou le revenu

k_respecte, min_k = check_k_anonymity(synth_ctgan, quasi_ids, k=3)
l_respecte, min_l = check_l_diversity(synth_ctgan, quasi_ids, sensitive_col, l=2)

print(f"K-anonymat (k=3) respecté ? {k_respecte} (Min k actuel = {min_k})")
print(f"L-diversité (l=2) respectée ? {l_respecte} (Min l actuel = {min_l})")

